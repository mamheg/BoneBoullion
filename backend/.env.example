# Database — Postgres in prod, SQLite fallback in dev if unset
DATABASE_URL=

# Telegram order bot (manager notifications)
BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional secret to validate inbound webhook callbacks (U8)
TELEGRAM_WEBHOOK_SECRET=

# Admin account (seeded on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# CORS: comma-separated allowed origins (frontend URLs)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Where uploaded product photos are stored (served at /media)
MEDIA_DIR=uploads

# Admin session lifetime (hours)
SESSION_TTL_HOURS=168
