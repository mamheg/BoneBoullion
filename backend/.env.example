# Database — Postgres in prod, SQLite fallback in dev if unset
DATABASE_URL=

# Telegram order bot (manager notifications)
BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional secret to validate inbound webhook callbacks (U8)
TELEGRAM_WEBHOOK_SECRET=
# Proxy/VPN list for reaching Telegram from RU hosts (comma or newline separated).
# Each entry is a proxy URL; bare host:port is treated as socks5://host:port.
# The pool rotates and sticks to the last working route; direct is tried last.
# Also editable at runtime via admin setting "telegram_proxies".
# Example: socks5://user:pass@1.2.3.4:1080,http://5.6.7.8:8080,127.0.0.1:1080
TELEGRAM_PROXIES=

# Admin account (seeded on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# CORS: comma-separated allowed origins (frontend URLs)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Where uploaded product photos are stored (served at /media)
MEDIA_DIR=uploads

# Admin session lifetime (hours)
SESSION_TTL_HOURS=168
